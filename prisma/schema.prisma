generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" 
}

model Movie {
  id    String @id @default(uuid())
  title String
}

model User{
  id    String @id @default(uuid())
  name String
  email String @unique
}
model Genre {
  id      Int      @id @default(autoincrement())
  name    String   @unique
}

//решил не создавать новый проект чтобы сделать домашнее задание из за этого пишу здесь
enum TaskStatus {
  todo
  in_progress
  done
}

model Board {
  id        Int      @id @default(autoincrement())
  title     String
  createdAt DateTime @default(now())

  tasks     Task[]
}

model Task {
  id          Int        @id @default(autoincrement())
  title       String
  description String?
  status      TaskStatus

  boardId    Int
  board      Board      @relation(fields: [boardId], references: [id])

  userId     Int
  user       User_HM32       @relation(fields: [userId], references: [id])

  createdAt  DateTime   @default(now())
}

model User_HM32 {
  id    Int    @id @default(autoincrement())
  name  String
  email String @unique

  tasks Task[]
}