generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" 
}

model Movie {
  id      String   @id @default(uuid())
  title   String
  year    Int?
  reviews Review[]
  genre   Genre?   @relation(fields: [genreId], references: [id])
  genreId Int?

  @@index([year])
  @@index([title])
  @@index([title, year])
}

model User{
  id      String   @id @default(uuid())
  name    String
  email   String   @unique
  password String 

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  reviews Review[]
}

model Review {
  id        String   @id @default(uuid())
  rating    Int      // 1-5 stars
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  movieId String
  movie   Movie   @relation(fields: [movieId], references: [id], onDelete: Cascade)

  userId  String
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([movieId, userId])
}
model Genre {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  movies Movie[]
}

//решил не создавать новый проект чтобы сделать домашнее задание из за этого пишу здесь
enum TaskStatus {
  todo
  in_progress
  done
}

model Board {
  id        Int      @id @default(autoincrement())
  title     String
  createdAt DateTime @default(now())

  tasks     Task[]
}

model Task {
  id          Int        @id @default(autoincrement())
  title       String
  description String?
  status      TaskStatus

  boardId    Int
  board      Board      @relation(fields: [boardId], references: [id])

  userId     Int
  user       User_HM32       @relation(fields: [userId], references: [id])

  createdAt  DateTime   @default(now())
}

model User_HM32 {
  id    Int    @id @default(autoincrement())
  name  String
  email String @unique

  tasks Task[]
}